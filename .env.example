# Firebase Web Config (get from Firebase Console > Project Settings > General > Your apps)
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=test-11432.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://test-11432-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=test-11432
VITE_FIREBASE_STORAGE_BUCKET=test-11432.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# Groq API key for AI features
VITE_GROQ_API_KEY=your_groq_api_key_here

# Ondoku TTS (matches curl base fields: text, voice, speed, pitch)
VITE_ONDOKU_TTS_PROXY_URL=/api/ondoku-tts
VITE_ONDOKU_TTS_VOICE=ja-JP-NaokiNeural
VITE_ONDOKU_TTS_SPEED=1
VITE_ONDOKU_TTS_PITCH=0

# Server-side Ondoku proxy config (used by Vite dev server)
ONDOKU_TTS_URL=https://ondoku3.com/vi/text_to_speech/
ONDOKU_TTS_ORIGIN=https://ondoku3.com
ONDOKU_TTS_REFERER=https://ondoku3.com/vi/
ONDOKU_TTS_ACCEPT_LANGUAGE=vi,en-US;q=0.9,en;q=0.8
ONDOKU_TTS_USER_AGENT=Mozilla/5.0 (Linux; Android 6.0; Nexus 5 Build/MRA58N) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.0.0 Mobile Safari/537.36
ONDOKU_LANGUAGE=ja-JP
ONDOKU_CSRF_TOKEN=
ONDOKU_COOKIE=
